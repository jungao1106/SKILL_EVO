LLM_PROVIDER=openai

# Generic OpenAI-compatible provider. Use this for GLM 5.1, GPT 5.5, Claude,
# or any router that exposes an OpenAI-compatible base URL plus model name.
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=https://api.novita.ai/v3/openai
OPENAI_COMPAT_MODEL=zai-org/glm-5.1
OPENAI_COMPAT_API=openai-completions
OPENAI_COMPAT_CONTEXT_WINDOW=128000
OPENAI_COMPAT_MAX_TOKENS=32000
OPENAI_COMPAT_THINKING_AS_TEXT=true
OPENAI_COMPAT_THINKING_FORMAT=zai

# For GPT 5.5 through a Responses-shaped endpoint:
# OPENAI_COMPAT_BASE_URL=https://pi-api.macaron.xin
# OPENAI_COMPAT_MODEL=gpt-5.5
# OPENAI_COMPAT_API=openai-responses
# OPENAI_COMPAT_THINKING_AS_TEXT=false
#
# For Claude through an OpenAI-compatible router:
# OPENAI_COMPAT_BASE_URL=https://your-router.example/v1
# OPENAI_COMPAT_MODEL=claude-sonnet-4-5
# OPENAI_COMPAT_API=openai-completions
# OPENAI_COMPAT_THINKING_AS_TEXT=false

# Tinker path kept as a separate provider profile.
TINKER_API_KEY=
TINKER_BASE_URL=https://tinker.thinkingmachines.dev/services/tinker-prod/oai/api/v1
TINKER_MODEL=nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-BF16:peft:262144
TINKER_API=openai-completions
TINKER_CONTEXT_WINDOW=262144
TINKER_MAX_TOKENS=32000
TINKER_THINKING_FORMAT=zai

E2B_API_KEY=
E2B_CONCURRENCY=10
E2B_TEMPLATE_NAMESPACE=anchen1011
E2B_PI_TEMPLATE_SUFFIX=pi_c6d7003a
E2B_SANDBOX_TIMEOUT_SEC=3600
E2B_OVERRIDE_CPUS=1
E2B_OVERRIDE_MEMORY_MB=4096
E2B_OVERRIDE_STORAGE_MB=10240

TIMEOUT_MULTIPLIER=1.0
AGENT_TIMEOUT_MULTIPLIER=
VERIFIER_TIMEOUT_MULTIPLIER=
AGENT_SETUP_TIMEOUT_MULTIPLIER=2.0
ENVIRONMENT_BUILD_TIMEOUT_MULTIPLIER=2.0
AGENT_SETUP_TIMEOUT_SEC=1200
AGENT_TIMEOUT_SEC=

HARBOR_DATASET=swe-bench/swe-bench-verified@2
JOB_NAME=pi_openai_glm51_skills

PI_USE_SKILLS=true
PI_THINKING=off
PI_TOOLS=read,write,edit,bash,grep,find,ls
RESULT_ONLY=false
